# WhatsApp Bridge Configuration
# ==============================

# Port for the Go bridge REST API
WHATSAPP_BRIDGE_PORT=8080

# Webhook URL for incoming messages (optional)
# Set this to forward incoming WhatsApp messages to another service
WEBHOOK_URL=http://localhost:8769/whatsapp/webhook

# Forward messages sent by self (true/false)
FORWARD_SELF=false

# Bearer token used to authenticate REST callers. The bridge generates one
# automatically at first start and writes it to whatsapp-bridge/store/.bridge-token
# (mode 0600). Override here to inject a token from the outside (e.g. from a
# secret store in a container) instead of mounting the file.
# WHATSAPP_BRIDGE_TOKEN=

# Colon-separated absolute paths that /api/send may read media files from.
# Default: ~/.local/share/whatsapp-mcp/outbox (created on first use). Files
# outside the listed roots are rejected with 403, defending against arbitrary-
# file-read abuse via media_path.
# WHATSAPP_MEDIA_ROOTS=/Users/yourname/.local/share/whatsapp-mcp/outbox:/Users/yourname/Pictures/wa-outbox


# MCP Server Configuration
# ========================

# Path to the SQLite messages database
# Default: relative path to whatsapp-bridge/store/messages.db
WHATSAPP_DB_PATH=./whatsapp-bridge/store/messages.db

# Path to whatsmeow's SQLite database (used to resolve LIDs ↔ phone numbers)
# Default: relative path to whatsapp-bridge/store/whatsapp.db
WHATSMEOW_DB_PATH=./whatsapp-bridge/store/whatsapp.db

# Go bridge REST API URL
WHATSAPP_API_URL=http://localhost:8080/api

# Bridge auto-start
# -----------------
# When the MCP server starts (or a send/download call finds the bridge
# unreachable on a loopback address), it starts the bridge automatically:
# it launches WHATSAPP_BRIDGE_BINARY detached, with output appended to
# whatsapp-bridge/store/bridge.log. If the binary is missing and Go is on
# PATH, it is built once with `go build`. First-time QR pairing still
# requires running the bridge manually in a terminal.
# Set to false to manage the bridge yourself (e.g. launchd/systemd).
WHATSAPP_BRIDGE_AUTOSTART=true

# Bridge binary used by auto-start.
# Default: whatsapp-bridge/whatsapp-bridge next to this repo's MCP server.
# WHATSAPP_BRIDGE_BINARY=/path/to/whatsapp-mcp/whatsapp-bridge/whatsapp-bridge

# Working directory for the auto-started bridge. The bridge resolves
# store/ (databases, token, media) relative to this directory.
# WHATSAPP_BRIDGE_DIR=/path/to/whatsapp-mcp/whatsapp-bridge

# Seconds to wait for an auto-started bridge to come online.
# WHATSAPP_BRIDGE_STARTUP_TIMEOUT=60
